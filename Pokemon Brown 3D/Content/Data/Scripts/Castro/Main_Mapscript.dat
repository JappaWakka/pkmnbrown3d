:endif

:if:<register.registered(AlexMissing)>=true
	@entity.Remove(16)
:endif

:if:<environment.graphicstyle>=false
	@Entity.Warp(17,~,~-3,~)
	@level.update
:else
	@Entity.Warp(18,~,~-3,~)
	@level.update
:endif

:if:<inventory.countitem(41)>=1 <and> <register.registered(Castro_JappaWakka)>=false
	@NPC.spawn(21,0,36,1,Castro\Main_JappaWakka,JappaWakka,0,1,JappaWakka,11,Still)
