version=2
:if:<Register.Registered(defeat<level.filename>)>=true
	@entity.warp(0,~,~-3,~)
	@entity.warp(1,~,~+3,~)
:endif

:if:<Register.Registered(RoomEnter<level.filename>)>=false
	@entity.warp(2,~,-2.5,~)
	@entity.warp(3,~,0.5,~)
	@player.stopmovement
	@player.move(2)
	@sound.play(SwitchDoor)
	@entity.warp(3,~,-2.5,~)
	@entity.warp(2,~,0.5,~)
	@Level.Update
	@Register.Register(RoomEnter<level.filename>)
:endif
:end
