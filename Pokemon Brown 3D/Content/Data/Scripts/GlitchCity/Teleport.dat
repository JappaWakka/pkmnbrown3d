version=2
@Player.Warp(GlitchCity\Teleport.dat,0,0.1,0,0)
@Level.Update
@Music.Stop
@Sound.Play(GlitchCityTeleport)
:if:<camera.thirdperson>=true
	@storage.set(bool,SetToFirstPerson,false)
:else
	@storage.set(bool,SetToFirstPerson,true)
:endif
@Camera.ActivateThirdPerson
@Camera.Fix
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Level.Update
@Level.Wait(5)
@Storage.Set(integer,SpinCount,0)
:while:<storage.get(integer,SpinCount)><8
	@player.turn(1)
	@Storage.Set(integer,SpinCount,<storage.get(integer,SpinCount)>+1)
	@Level.Update
	@Level.Wait(5)
	@Level.Update
	@Level.Wait(5)
	@Level.Update
	@Level.Wait(5)
	@Level.Update
	@Level.Wait(5)
:endwhile
@Storage.Set(integer,SpinCount,0)
:while:<storage.get(integer,SpinCount)><8
	@player.turn(1)
	@Storage.Set(integer,SpinCount,<storage.get(integer,SpinCount)>+1)
	@Level.Update
	@Level.Wait(5)
	@Level.Update
	@Level.Wait(5)
:endwhile
@Storage.Set(integer,SpinCount,0)
:while:<storage.get(integer,SpinCount)><8
	@player.turn(1)
	@Storage.Set(integer,SpinCount,<storage.get(integer,SpinCount)>+1)
	@Level.Update
	@Level.Wait(5)
:endwhile
@Storage.Set(integer,SpinCount,0)
:while:<storage.get(integer,SpinCount)><16
	@player.turn(1)
	@Storage.Set(integer,SpinCount,<storage.get(integer,SpinCount)>+1)
	@Level.Update
	@Level.Wait(2)
:endwhile
@Player.DoWalkAnimation(0)
:while:<player.position(y)><3
	@player.turn(1)
	@player.warp(~,~+0.1,~)
:endwhile
@screen.fadeoutcolor(255,255,255)
@screen.fadeout(15)
@Camera.Update
@Player.ResetMovement
@Player.Warp(GlitchCity\Main.dat,8,0.1,19,0,3)
@level.update
@camera.defix
@camera.update
@player.turnto(2)
@camera.setyaw(0)
@camera.fix
@player.warp(~,2.9,~)
@level.update
@level.Update
@Camera.Update
@screen.fadein(15)
@camera.update
@Player.SetMovement(0,-1,0)
@Player.SetSpeed(3)
@Player.Move(3)
@Player.DoWalkAnimation(1)

@camera.defix
@screen.fadeoutcolor
:if:<storage.get(bool,SetToFirstPerson)>=true
	@Camera.DeactivateThirdPerson
:endif
@Music.Play(GlitchCity)
:end
