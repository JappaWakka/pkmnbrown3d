version=2
@Text.Show(<system.token(Item_Use_UnstableFeather_Check)>)
:if:<system.contains(<level.levelfile>,Botan)>=true
	:if:<system.contains(<level.levelfile>,Area1.dat;Area2.dat;Area3.dat;Area3_MissingNo.dat;Area4.dat;Area4_MissingNo.dat;Area5.dat;Area5_MissingNo.dat;Area6.dat;Area6_MissingNo.dat)>=true
		@Text.Show(<system.token(Item_Use_UnstableFeather_HauntedForest)>)
