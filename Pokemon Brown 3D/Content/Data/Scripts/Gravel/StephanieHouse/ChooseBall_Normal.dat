version=2
@NPC.Turn(0,0)
:if:<Register.Registered(StephaniePokemonSwap)>=False
	:if:<player.badges>=0
		@Text.Show(<system.token(Gravel_StephanieHouse_ChooseBall_NormalBall)>*<system.token(Gravel_StephanieHouse_ChooseBall_Question)>)
		@Options.SetCancelIndex(1)
		@options.show(<system.token(global_yes)>,<system.token(global_no)>)
		:when:<system.token(global_yes)>
			@Storage.Set(int,PokemonID,<system.chooserandom(16,133)>)
			
			:if:<System.StartsWith(<pokedex.getname(<storage.get(int,PokemonID)>)>,e;a;o;u;i)>=true
				@Storage.Set(str,ReceiveMessage,<system.token(Gravel_StephanieHouse_ReceiveAnSwapPokemon)>)
			:else
				@Storage.Set(str,ReceiveMessage,<system.token(Gravel_StephanieHouse_ReceiveASwapPokemon)>)
			:endif
			
			@pokemon.npctrade(1,2,3,4,5,6,7,8,9|<storage.get(int,PokemonID)>|5|-1||<register.value(Shiny_StephanieSwap_NormalBall)>|<Player.OT>|Stephanie|5||<system.token(Gravel_StephanieHouse_SwapPokemon_CatchLocation)>|<system.token(Gravel_StephanieHouse_SwapPokemon_CatchMethod)>|||<system.token(Gravel_StephanieHouse_ChooseBall_WrongPokemon)>|StephanieCorrectPokemon|<storage.get(str,ReceiveMessage)>)
			
			:if:<Register.Registered(StephanieCorrectPokemon)>=true
				@pokemon.SetCatchTrainer(<pokemon.count>-1,<Player.Name>)
				@NPC.remove(2)
				@NPC.register(Gravel\StephanieHouse.dat|2|remove)
				@overworldpokemon.hide
				@pokemon.rename(<pokemon.count>-1)
				@Text.Show(<system.token(Gravel_StephanieHouse_ChooseBall_Yes)>)
				@Register.Register(StephaniePokemonSwap)
			:endif
			:end
		:when:<system.token(global_no)>
			@Text.Show(<system.token(Gravel_StephanieHouse_ChooseBall_No)>)
			:end
		:endwhen
	:else
		@Text.Show(<system.token(Gravel_StephanieHouse_NotChooseBall_AfterGotBadge)>)
	:endif
:else
	@Text.Show(<system.token(Gravel_StephanieHouse_AfterChooseBall_NormalBall)>)
:endif
:end
